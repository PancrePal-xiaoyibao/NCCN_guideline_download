# NCCN 下载脚本本地环境变量模板
# 复制为 .env 后按本地情况填写；不要把真实密钥提交到仓库。

# NCCN 认证：二选一或按实际使用
NCCN_AUTH_METHOD=cookie
NCCN_COOKIE_FILE=extracted_cookies.txt
# NCCN_COOKIE=

# 用户名密码认证（仅当 NCCN_AUTH_METHOD=username_password 时使用）
# NCCN_USERNAME=user@example.com
# NCCN_PASSWORD=

# 下载根目录
NCCN_DOWNLOAD_DIR=nccn_downloads

# MinerU
NCCN_MINERU_MODE=flash
NCCN_MINERU_LANGUAGE=en
MINERU_TOKEN=

# OCR 后端：mineru 或 deepseek-ocr
# NCCN_OCR_BACKEND=mineru
NCCN_OCR_BACKEND=deepseek-ocr

# SiliconFlow DeepSeek-OCR
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.xiao-x-bao.com.cn/v1
NCCN_DEEPSEEK_OCR_MODEL=deepseek-ai/DeepSeek-OCR
NCCN_DEEPSEEK_OCR_MAX_PAGES=0

# 翻译模型：默认使用 SiliconFlow glm-4.5-air
# SILICONFLOW_API_KEY=
# SILICONFLOW_MODEL=glm-4.5-air

# 兼容 OpenAI 接口配置（如不使用可留空）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.stepfun.com/v1
# OPENAI_MODEL=stepfun-3.5-flash
